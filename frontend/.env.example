# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Works with Supabase, Neon, Railway, or any pg.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/sorabase"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-secure-random-string"

# Base URL of your app. Used for OAuth redirect URIs.
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Console: https://console.cloud.google.com
# Authorized redirect URI to add: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Microsoft / Azure AD OAuth ────────────────────────────────────────────────
# Portal: https://portal.azure.com → App registrations
# Authorized redirect URI to add: {NEXTAUTH_URL}/api/auth/callback/azure-ad
# Use "common" as tenant to allow any Microsoft account, or set a specific tenant ID.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"
