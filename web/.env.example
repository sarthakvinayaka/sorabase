# ─── Backend API ───────────────────────────────────────────────────────────────

# Server-side URL used by Next.js server components to reach the FastAPI backend.
# On Vercel, set this to your deployed API URL (e.g. https://api.yourdomain.com).
# Leave unset to skip the /health check on the home page.
SERVER_API_URL=http://127.0.0.1:8000

# Next.js rewrite proxy destination for /api/* routes (used in next.config.ts).
# Set to your backend URL in production if using the built-in proxy.
# Not needed if you set NEXT_PUBLIC_API_URL instead.
API_PROXY_ORIGIN=http://127.0.0.1:8000

# Browser-side API base URL. Set this when the API is on a different origin than
# the frontend. Leave unset to use the /api proxy (default for local dev).
# Example: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# ─── Site URL ──────────────────────────────────────────────────────────────────

# Canonical URL for OpenGraph metadata and canonical links.
# On Vercel this falls back to VERCEL_URL automatically — only set it if you
# have a custom domain configured.
# Example: https://app.sorabase.com
NEXT_PUBLIC_SITE_URL=

# ─── App Defaults ──────────────────────────────────────────────────────────────

# Default organization ID loaded into the analytics and upload pages.
# Useful for single-tenant deployments or demos.
NEXT_PUBLIC_DEV_ORG_ID=

# Default recruiter ID pre-filled in the audio upload form.
NEXT_PUBLIC_DEV_RECRUITER_ID=

# Default editor user ID used in the review console and export panel.
# Falls back to a hard-coded seed UUID when unset.
NEXT_PUBLIC_DEV_EDITOR_USER_ID=
